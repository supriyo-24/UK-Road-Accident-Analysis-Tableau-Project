      <aliases enabled='yes' />
      <column caption='Accident Severity' datatype='string' name='[Accident_Severity]' role='dimension' type='nominal' />
      <column caption='PY ACCIDENTS ' datatype='integer' name='[CY ACCIDENTS (copy)_1463761487851523]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT (IF YEAR([Accident Date]) = [Parameters].[CURRENT YEAR (copy)_1463761484832769] THEN [Index] END)' />
      </column>
      <column caption='PY CASUALTIES ' datatype='integer' name='[CY CASUALTIES (copy)_1463761492418566]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Accident Date])=[Parameters].[CURRENT YEAR (copy)_1463761484832769] THEN [Number_of_Casualties] END)' />
      </column>
      <column caption='PY FATAL CASUALTIES ' datatype='integer' name='[CY FATAL CASUALTIES (copy)_1463761494503433]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Accident_Severity] = &apos;Fatal&apos; and YEAR([Accident Date]) = [Parameters].[CURRENT YEAR (copy)_1463761484832769] THEN [Number_of_Casualties] END)' />
      </column>
      <column caption='CY SERIOUS CASUALTIES ' datatype='integer' name='[CY FATAL CASUALTIES (copy)_1463761495236619]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Accident_Severity] = &apos;Serious&apos; and YEAR([Accident Date]) = [Parameters].[Parameter 1] THEN [Number_of_Casualties] END)' />
      </column>
      <column caption='CY SLIGHT CASUALTIES' datatype='integer' name='[CY FATAL CASUALTIES (copy)_1463761496649742]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Accident_Severity] = &apos;Slight&apos; and YEAR([Accident Date]) = [Parameters].[Parameter 1] THEN [Number_of_Casualties] END)' />
      </column>
      <column caption='PY SERIOUS CASUALTIES' datatype='integer' name='[CY SERIOUS CASUALTIES  (copy)_1463761495748620]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Accident_Severity] = &apos;Serious&apos; and YEAR([Accident Date]) = [Parameters].[CURRENT YEAR (copy)_1463761484832769] THEN [Number_of_Casualties] END)' />
      </column>
      <column caption='PY SLIGHT CASUALTIES' datatype='integer' name='[CY SLIGHT CASUALTIES (copy)_1463761497071631]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Accident_Severity] = &apos;Slight&apos; and YEAR([Accident Date]) = [Parameters].[CURRENT YEAR (copy)_1463761484832769] THEN [Number_of_Casualties] END)' />
      </column>
      <column caption='ACCIDENT SEVERITY FILTER' datatype='boolean' name='[Calculation_0987673014984704]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 2] = [Accident_Severity]&#13;&#10;OR [Parameters].[Parameter 2] = &quot;All&quot;' />
      </column>
      <column aggregation='Sum' caption='YEAR OF ACCIDENT DATE' datatype='integer' name='[Calculation_1463761483177984]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='YEAR([Accident Date])' />
      </column>
      <column caption='CY ACCIDENTS' datatype='integer' name='[Calculation_1463761485950978]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT (IF YEAR([Accident Date]) = [Parameters].[Parameter 1] THEN [Index] END)' />
      </column>
      <column caption='YOY ACCIDENTS' datatype='real' default-format='*▲0.00%;▼0.00%' name='[Calculation_1463761488658436]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1463761485950978]-[CY ACCIDENTS (copy)_1463761487851523])/[CY ACCIDENTS (copy)_1463761487851523]' />
      </column>
      <column caption='CY CASUALTIES' datatype='integer' name='[Calculation_1463761491742725]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([Accident Date])=[Parameters].[Parameter 1] THEN [Number_of_Casualties] END)' />
      </column>
      <column caption='CY FATAL CASUALTIES' datatype='integer' name='[Calculation_1463761493630984]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Accident_Severity] = &apos;Fatal&apos; and YEAR([Accident Date]) = [Parameters].[Parameter 1] THEN [Number_of_Casualties] END)' />
      </column>
